<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Mona Mayhem - GitHub Contribution Battle Arena</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
		<style>
			:root {
				--bg-color: #0a0a1a;
				--theme-primary: #5fed83;
				--theme-primary-rgb: 95, 237, 131;
				--theme-primary-dark: #1f7a33;
				--theme-accent: #8a2be2;
				--theme-accent-rgb: 138, 43, 226;
				--theme-accent-dark: #4a157a;
			}
			body[data-theme='neon-blaze'] {
				--theme-primary: #00f5ff;
				--theme-primary-rgb: 0, 245, 255;
				--theme-primary-dark: #0f7f8a;
				--theme-accent: #ff6b35;
				--theme-accent-rgb: 255, 107, 53;
				--theme-accent-dark: #8a3517;
			}
			body {
				font-family: 'Press Start 2P', system-ui, sans-serif;
				background-color: var(--bg-color);
				color: white;
				max-width: 900px;
				margin: 0 auto;
				padding: 2rem;
				text-align: center;
				position: relative;
			}
			/* CRT Overlay */
			body::after {
				content: "";
				position: fixed;
				top: 0; left: 0; width: 100vw; height: 100vh;
				background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
				background-size: 100% 2px, 3px 100%;
				z-index: 9999;
				pointer-events: none;
			}
			h1 {
				animation: neon-flicker 3s infinite alternate;
				color: var(--theme-primary);
				line-height: 1.5;
				font-size: 1.5rem;
			}
			@keyframes neon-flicker {
				0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% { 
					text-shadow: 0 0 2px var(--theme-primary), 0 0 7px var(--theme-primary);
					opacity: 1;
				}
				20%, 24%, 55% { 
					text-shadow: none; 
					opacity: 0.8;
				}
			}
			p {
				font-size: 0.8rem;
				line-height: 1.4;
			}
			.battle-form {
				display: flex;
				justify-content: center;
				gap: 1rem;
				margin: 2rem 0;
				align-items: center;
				animation: float-in 1s ease-out forwards;
				opacity: 0;
				transform: translateY(20px);
			}
			.battle-form.shake-error {
				animation: float-in 1s ease-out forwards, shake-error 0.45s ease-in-out;
			}
			@keyframes float-in {
				to { opacity: 1; transform: translateY(0); }
			}
			@keyframes shake-error {
				0%, 100% { transform: translateX(0); }
				20% { transform: translateX(-8px); }
				40% { transform: translateX(8px); }
				60% { transform: translateX(-6px); }
				80% { transform: translateX(6px); }
			}
			input {
				padding: 0.75rem;
				font-size: 0.8rem;
				font-family: 'Press Start 2P', system-ui, sans-serif;
				background-color: #111;
				color: var(--theme-primary);
				border: 2px solid var(--theme-accent);
				border-bottom: 6px solid var(--theme-accent-dark); /* Chunky Arcade border */
				border-radius: 4px;
				outline: none;
				transition: transform 0.1s, border-bottom-width 0.1s;
			}
			input.input-invalid {
				border-color: #ff3366;
				border-bottom-color: #8c1c3c;
				box-shadow: 0 0 10px #ff3366;
			}
			input:focus {
				border-color: var(--theme-primary);
				border-bottom-color: var(--theme-primary-dark);
				box-shadow: 0 0 10px var(--theme-primary);
			}
			input.input-invalid:focus {
				border-color: #ff3366;
				border-bottom-color: #8c1c3c;
				box-shadow: 0 0 10px #ff3366, 0 0 20px rgba(255, 51, 102, 0.5);
			}
			input:focus-visible {
				outline: 3px solid #fff;
				outline-offset: 2px;
			}
			button {
				padding: 0.75rem 1.5rem;
				font-size: 0.8rem;
				font-family: 'Press Start 2P', system-ui, sans-serif;
				background-color: var(--theme-primary);
				color: #000;
				border: 2px solid #fff;
				border-bottom: 6px solid var(--theme-primary-dark); /* Chunky Arcade border */
				border-radius: 6px;
				cursor: pointer;
				transition: transform 0.1s, border-bottom-width 0.1s;
			}
			button:focus-visible {
				outline: 3px solid #fff;
				outline-offset: 3px;
				box-shadow: 0 0 10px var(--theme-primary);
			}
			.theme-toggle {
				margin-bottom: 1.5rem;
				font-size: 0.6rem;
				padding: 0.6rem 1rem;
			}
			.sound-toggle {
				margin-left: 0.5rem;
				margin-bottom: 1.5rem;
				font-size: 0.6rem;
				padding: 0.6rem 1rem;
				background-color: var(--theme-accent);
				border-bottom-color: var(--theme-accent-dark);
			}
			.battle-overlay {
				position: fixed;
				inset: 0;
				display: none;
				align-items: center;
				justify-content: center;
				background: radial-gradient(circle at center, rgba(var(--theme-accent-rgb), 0.32), rgba(0, 0, 0, 0.88));
				z-index: 999;
				padding: 1rem;
			}
			.battle-overlay.visible {
				display: flex;
				animation: overlay-flicker 0.24s steps(2) infinite alternate;
			}
			.countdown-text {
				font-size: clamp(1.6rem, 7vw, 3.4rem);
				line-height: 1.2;
				color: #fff;
				text-transform: uppercase;
				text-align: center;
				text-shadow: 0 0 8px var(--theme-primary), 0 0 18px var(--theme-accent), 0 0 30px rgba(255, 255, 255, 0.6);
				letter-spacing: 0.12em;
				opacity: 0;
				transform: scale(0.75);
			}
			.countdown-text.step {
				animation: countdown-pop 0.95s steps(8) forwards;
			}
			#battle-results.results-slide-in {
				animation: results-slide-in 0.7s cubic-bezier(0.18, 1, 0.32, 1) both;
			}
			#battle-results.results-slide-in .player-result {
				animation: card-slide-in 0.65s cubic-bezier(0.22, 1, 0.36, 1) both;
			}
			#battle-results.results-slide-in .player-result:nth-child(1) {
				animation-delay: 0.05s;
			}
			#battle-results.results-slide-in .player-result:nth-child(3) {
				animation-delay: 0.14s;
			}
			@keyframes overlay-flicker {
				0% { filter: brightness(0.96); }
				100% { filter: brightness(1.04); }
			}
			@keyframes countdown-pop {
				0% { opacity: 0; transform: scale(0.65); }
				18% { opacity: 1; transform: scale(1.22); }
				72% { opacity: 1; transform: scale(1); }
				100% { opacity: 0; transform: scale(0.86); }
			}
			@keyframes results-slide-in {
				0% { opacity: 0; transform: translateY(24px); }
				100% { opacity: 1; transform: translateY(0); }
			}
			@keyframes card-slide-in {
				0% { opacity: 0; transform: translateX(-24px); }
				100% { opacity: 1; transform: translateX(0); }
			}
			button:active {
				transform: translateY(4px);
				border-bottom-width: 2px;
			}
			#battle-results {
				margin-top: 2rem;
				padding: 1rem;
				border: 2px solid var(--theme-accent);
				border-radius: 8px;
				display: none;
				background-color: rgba(var(--theme-accent-rgb), 0.1);
				box-shadow: 0 0 15px var(--theme-accent);
			}
			.history-section {
				margin-top: 2rem;
				padding: 1rem;
				border: 2px solid #2f2f2f;
				border-radius: 8px;
				background: rgba(255, 255, 255, 0.03);
				box-shadow: 0 0 10px rgba(0, 0, 0, 0.4);
			}
			.history-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.75rem;
				flex-wrap: wrap;
			}
			.clear-history-btn {
				font-size: 0.58rem;
				padding: 0.55rem 0.85rem;
				background-color: #ff6f00;
				border-bottom-color: #c95800;
			}
			.clear-history-btn:focus-visible {
				box-shadow: 0 0 10px #ff6f00;
			}
			.recent-battles-list {
				list-style: none;
				padding: 0;
				margin: 1rem 0 0;
				display: flex;
				flex-direction: column;
				gap: 0.7rem;
			}
			.recent-battle-item {
				padding: 0.75rem;
				border: 2px solid rgba(255, 255, 255, 0.15);
				border-radius: 8px;
				background: linear-gradient(90deg, rgba(var(--theme-primary-rgb), 0.09), rgba(var(--theme-accent-rgb), 0.08));
			}
			.recent-battle-top {
				display: flex;
				justify-content: space-between;
				gap: 0.75rem;
				align-items: baseline;
				flex-wrap: wrap;
			}
			.recent-battle-winner {
				color: var(--theme-primary);
				text-shadow: 0 0 8px rgba(var(--theme-primary-rgb), 0.65);
			}
			.recent-battle-time {
				font-size: 0.55rem;
				opacity: 0.85;
			}
			.recent-battle-score {
				margin-top: 0.45rem;
				font-size: 0.6rem;
				line-height: 1.7;
			}
			.recent-battle-empty {
				margin-top: 1rem;
				font-size: 0.6rem;
				opacity: 0.85;
			}
			.winner-banner {
				display: none;
				margin: 0.75rem 0 0;
				padding: 0.85rem 1rem;
				text-align: center;
				font-size: 0.75rem;
				line-height: 1.5;
				letter-spacing: 0.06em;
				border: 2px solid #fff;
				border-radius: 8px;
				background: linear-gradient(120deg, rgba(var(--theme-primary-rgb), 0.26), rgba(var(--theme-accent-rgb), 0.34), rgba(var(--theme-primary-rgb), 0.26));
				background-size: 230% 100%;
				color: #fff;
				text-shadow: 0 0 10px rgba(255, 255, 255, 0.65);
				box-shadow: 0 0 14px rgba(var(--theme-accent-rgb), 0.6), inset 0 0 10px rgba(255, 255, 255, 0.08);
				position: relative;
				overflow: hidden;
			}
			.winner-banner.visible {
				display: block;
				animation: winner-banner-pop 0.42s steps(6) forwards, winner-banner-scan 2s linear infinite;
			}
			.winner-banner.visible::before,
			.winner-banner.visible::after {
				content: "";
				position: absolute;
				inset: 0;
				pointer-events: none;
			}
			.winner-banner.visible::before {
				background:
					radial-gradient(circle at 15% 30%, rgba(255, 255, 255, 0.25) 0 6px, transparent 8px),
					radial-gradient(circle at 85% 35%, rgba(255, 255, 255, 0.3) 0 5px, transparent 7px),
					radial-gradient(circle at 25% 75%, rgba(255, 255, 255, 0.22) 0 5px, transparent 7px),
					radial-gradient(circle at 80% 78%, rgba(255, 255, 255, 0.26) 0 4px, transparent 6px);
				animation: winner-banner-sparkle 1.35s ease-in-out infinite alternate;
			}
			.winner-banner.visible::after {
				border: 2px dashed rgba(255, 255, 255, 0.3);
				border-radius: 6px;
				animation: winner-banner-ring 1.1s ease-in-out infinite;
			}
			.winner-banner.tie {
				background: linear-gradient(120deg, rgba(var(--theme-accent-rgb), 0.24), rgba(255, 255, 255, 0.2), rgba(var(--theme-primary-rgb), 0.24));
			}
			@keyframes winner-banner-pop {
				0% { transform: scale(0.85); opacity: 0; }
				70% { transform: scale(1.05); opacity: 1; }
				100% { transform: scale(1); opacity: 1; }
			}
			@keyframes winner-banner-scan {
				0% { background-position: 0% 0%; }
				100% { background-position: 230% 0%; }
			}
			@keyframes winner-banner-sparkle {
				0% { opacity: 0.4; transform: translateY(-2px); }
				100% { opacity: 0.95; transform: translateY(2px); }
			}
			@keyframes winner-banner-ring {
				0%,
				100% { transform: scale(0.985); opacity: 0.55; }
				50% { transform: scale(1); opacity: 1; }
			}
			.result-card {
				display: flex;
				justify-content: space-around;
				margin-top: 1rem;
				gap: 1rem;
				align-items: center;
			}
			.vs-badge {
				font-size: 1.5rem;
				font-weight: bold;
				background: linear-gradient(90deg, var(--theme-primary), var(--theme-accent), var(--theme-primary));
				background-size: 200% auto;
				color: transparent;
				-webkit-background-clip: text;
				background-clip: text;
				animation: gradient-shift 2s linear infinite, dramatic-pulse 1.5s ease-in-out infinite alternate;
			}
			@keyframes gradient-shift {
				to { background-position: 200% center; }
			}
			@keyframes dramatic-pulse {
				0% { 
					transform: scale(1); 
					filter: drop-shadow(0 0 5px var(--theme-accent));
				}
				100% { 
					transform: scale(1.25); 
					filter: drop-shadow(0 0 15px var(--theme-primary));
				}
			}
			.player-result {
				padding: 1rem;
				border: 2px solid #333;
				border-radius: 8px;
				width: 45%;
				overflow: hidden;
				position: relative;
				background-color: #111;
			}
			.player-result::after {
				content: "";
				position: absolute;
				top: 0; left: -100%;
				width: 50%; height: 100%;
				background: linear-gradient(to right, transparent, rgba(255,255,255,0.3), transparent);
				transform: skewX(-20deg);
				animation: shimmer 3s infinite;
			}
			@keyframes shimmer {
				0% { left: -100%; }
				20% { left: 200%; }
				100% { left: 200%; }
			}
			.winner {
				border-color: var(--theme-primary);
				background-color: rgba(var(--theme-primary-rgb), 0.1);
				box-shadow: 0 0 15px var(--theme-primary);
			}
			.winner::before {
				content: "";
				position: absolute;
				top: 50%;
				left: 50%;
				width: 12px;
				height: 12px;
				background: transparent;
				box-shadow: 
					-25px -25px 0 var(--theme-primary),
					25px -25px 0 var(--theme-accent),
					-25px 25px 0 var(--theme-accent),
					25px 25px 0 var(--theme-primary),
					0 -35px 0 #fff,
					0 35px 0 #fff,
					-35px 0 0 #fff,
					35px 0 0 #fff,
					-15px -40px 0 var(--theme-primary),
					40px 15px 0 var(--theme-accent);
				animation: pixel-burst 0.8s steps(6) forwards;
				z-index: 20;
				pointer-events: none;
			}
			@keyframes pixel-burst {
				0% { transform: translate(-50%, -50%) scale(0); opacity: 1; }
				50% { transform: translate(-50%, -50%) scale(1.5); opacity: 1; }
				100% { transform: translate(-50%, -50%) scale(3); opacity: 0; }
			}
			.loser {
				border-color: #ff0055;
				background-color: rgba(255, 0, 85, 0.1);
				box-shadow: 0 0 15px #ff0055;
			}
			.error-message {
				color: #ff3366;
				font-weight: bold;
				text-shadow: 0 0 4px #ff3366, 0 0 10px rgba(255, 51, 102, 0.8);
			}
			.form-error-message {
				display: none;
				margin: -1rem auto 1.5rem;
				max-width: 760px;
				padding: 0.75rem;
				border: 2px solid #ff3366;
				border-radius: 6px;
				background-color: rgba(255, 51, 102, 0.12);
				color: #ff3366;
				font-size: 0.65rem;
				line-height: 1.5;
				text-shadow: 0 0 4px #ff3366, 0 0 10px rgba(255, 51, 102, 0.8);
				box-shadow: 0 0 10px rgba(255, 51, 102, 0.6);
			}
			.form-error-message.visible {
				display: block;
			}
			.contrib-grid {
				display: flex;
				gap: 4px;
				margin-top: 1rem;
				overflow-x: auto;
				padding-bottom: 1rem;
			}
			.contrib-legend {
				display: flex;
				align-items: center;
				gap: 0.45rem;
				font-size: 0.52rem;
				margin-top: 0.15rem;
				opacity: 0.95;
			}
			.contrib-legend-scale {
				display: inline-flex;
				align-items: center;
				gap: 0.22rem;
			}
			.contrib-legend-cell {
				width: 11px;
				height: 11px;
				border-radius: 2px;
				border: 1px solid rgba(255, 255, 255, 0.2);
			}
			.contrib-week {
				display: flex;
				flex-direction: column;
				gap: 4px;
			}
			.contrib-day {
				width: 12px;
				height: 12px;
				border-radius: 2px;
				border: 1px solid rgba(255,255,255,0.1);
				transition: transform 0.2s, box-shadow 0.2s;
			}
			.contrib-day:hover {
				transform: scale(1.5);
				box-shadow: 0 0 5px currentColor, 0 0 10px currentColor;
				z-index: 10;
				position: relative;
			}
			.loading-pulse, .loading-text {
				animation: color-shift 1s infinite alternate;
				font-size: 0.6rem;
			}
			@keyframes color-shift {
				0% { color: var(--theme-primary); text-shadow: 0 0 5px var(--theme-primary); }
				100% { color: var(--theme-accent); text-shadow: 0 0 5px var(--theme-accent); }
			}
			h2, h3 { font-size: 1rem; }
			@media (max-width: 1024px) {
				.result-card {
					flex-direction: column;
				}
				.player-result {
					width: 100%;
				}
				.vs-badge {
					margin: 0.5rem 0;
				}
			}
			@media (max-width: 768px) {
				body {
					padding: 1rem;
				}
				h1 {
					font-size: 1.15rem;
					line-height: 1.4;
				}
				p {
					font-size: 0.65rem;
				}
				h2, h3 {
					font-size: 0.8rem;
				}
				.battle-form {
					flex-direction: column;
					gap: 0.75rem;
					width: 100%;
				}
				input,
				button {
					width: 100%;
					max-width: 420px;
					font-size: 0.65rem;
				}
				#battle-results {
					padding: 0.75rem;
				}
				.history-section {
					padding: 0.75rem;
				}
				.form-error-message {
					font-size: 0.55rem;
					margin-top: -0.75rem;
				}
				.contrib-day {
					width: 10px;
					height: 10px;
				}
				.contrib-legend {
					font-size: 0.5rem;
				}
				.contrib-legend-cell {
					width: 10px;
					height: 10px;
				}
				.loading-pulse,
				.loading-text {
					font-size: 0.5rem;
				}
			}
		</style>
	</head>
	<body>
		<h1>Mona Mayhem - GitHub Contribution Battle Arena</h1>
		<p>Enter two GitHub usernames to see who has the most contributions!</p>
		<button id="theme-toggle" class="theme-toggle" type="button" aria-pressed="false">
			Theme: Classic
		</button>
		<button id="sound-toggle" class="sound-toggle" type="button" aria-pressed="false">
			Sound: On
		</button>

		<div id="battle-overlay" class="battle-overlay" aria-live="assertive" aria-atomic="true">
			<p id="countdown-text" class="countdown-text">3...</p>
		</div>

		<form class="battle-form" aria-label="Battle setup form">
			<input type="text" id="player1" placeholder="Player 1 username" aria-label="Player 1 username" />
			<span>VS</span>
			<input type="text" id="player2" placeholder="Player 2 username" aria-label="Player 2 username" />
			<button id="battle-btn" type="submit">Battle!</button>
		</form>
		<p id="form-error" class="form-error-message" role="alert" aria-live="assertive"></p>

		<div id="battle-results" tabindex="-1" aria-live="polite">
			<h2>Battle Results!</h2>
			<p id="winner-banner" class="winner-banner" aria-live="assertive"></p>
			<div class="result-card">
				<div class="player-result winner" id="result-player1">
					<h3>Player 1</h3>
					<p class="loading-text">Loading...</p>
				</div>
				<div class="vs-badge">VS</div>
				<div class="player-result loser" id="result-player2">
					<h3>Player 2</h3>
					<p class="loading-text">Loading...</p>
				</div>
			</div>
		</div>

		<section class="history-section" aria-labelledby="recent-battles-title">
			<div class="history-header">
				<h2 id="recent-battles-title">Recent Battles</h2>
				<button id="clear-history-btn" class="clear-history-btn" type="button">Clear History</button>
			</div>
			<ul id="recent-battles-list" class="recent-battles-list" aria-live="polite"></ul>
		</section>

		<script>
			interface ContributionDay {
				weekday: number;
				count: number;
				level: number;
			}
			interface Week {
				index: number;
				first_day: string;
				contribution_days: ContributionDay[];
			}
			interface ContributionData {
				total_contributions: number;
				from: string;
				to: string;
				colors_full: string[];
				weeks: Week[];
				error?: string;
			}
			interface BattleHistoryEntry {
				player1: string;
				player1Total: number;
				player2: string;
				player2Total: number;
				winner: string;
				battledAt: string;
			}

			const p1Input = document.getElementById('player1') as HTMLInputElement | null;
			const p2Input = document.getElementById('player2') as HTMLInputElement | null;
			const resultsArea = document.getElementById('battle-results');
			const resultP1 = document.getElementById('result-player1');
			const resultP2 = document.getElementById('result-player2');
			const winnerBanner = document.getElementById('winner-banner') as HTMLParagraphElement | null;
			const battleOverlay = document.getElementById('battle-overlay') as HTMLDivElement | null;
			const countdownText = document.getElementById('countdown-text') as HTMLParagraphElement | null;
			const recentBattlesList = document.getElementById('recent-battles-list') as HTMLUListElement | null;
			const clearHistoryBtn = document.getElementById('clear-history-btn') as HTMLButtonElement | null;
			const battleForm = document.querySelector('.battle-form') as HTMLFormElement | null;
			const battleBtn = document.getElementById('battle-btn') as HTMLButtonElement | null;
			const formError = document.getElementById('form-error') as HTMLParagraphElement | null;
			const themeToggle = document.getElementById('theme-toggle') as HTMLButtonElement | null;
			const soundToggle = document.getElementById('sound-toggle') as HTMLButtonElement | null;
			const githubUsernameRegex = /^(?!-)(?!.*--)[a-zA-Z0-9-]{1,39}(?<!-)$/;
			const defaultTheme = 'classic';
			const altTheme = 'neon-blaze';
			const themeStorageKey = 'mona-mayhem-theme';
			const battleHistoryStorageKey = 'mona-mayhem-recent-battles';
			const soundMutedStorageKey = 'mona-mayhem-sound-muted';
			let audioContext: AudioContext | null = null;
			let isSoundMuted = false;
			let isBattleInProgress = false;

			const escapeHtml = (value: string): string => {
				return value
					.replace(/&/g, '&amp;')
					.replace(/</g, '&lt;')
					.replace(/>/g, '&gt;')
					.replace(/"/g, '&quot;')
					.replace(/'/g, '&#39;');
			};

			const applyTheme = (theme: string) => {
				if (theme === altTheme) {
					document.body.setAttribute('data-theme', altTheme);
					if (themeToggle) {
						themeToggle.textContent = 'Theme: Blue/Orange';
						themeToggle.setAttribute('aria-pressed', 'true');
					}
					return;
				}
				document.body.removeAttribute('data-theme');
				if (themeToggle) {
					themeToggle.textContent = 'Theme: Classic';
					themeToggle.setAttribute('aria-pressed', 'false');
				}
			};

			const ensureAudioContext = async (): Promise<AudioContext | null> => {
				if (typeof window === 'undefined') {
					return null;
				}

				if (!audioContext) {
					const AudioContextCtor = window.AudioContext || (window as typeof window & { webkitAudioContext?: typeof AudioContext }).webkitAudioContext;
					if (!AudioContextCtor) {
						return null;
					}
					audioContext = new AudioContextCtor();
				}

				if (audioContext.state === 'suspended') {
					await audioContext.resume();
				}

				return audioContext;
			};

			const playTone = (
				ctx: AudioContext,
				type: OscillatorType,
				startTime: number,
				duration: number,
				fromFreq: number,
				toFreq: number,
				startGain: number,
				endGain: number
			) => {
				const osc = ctx.createOscillator();
				const gain = ctx.createGain();
				osc.type = type;
				osc.frequency.setValueAtTime(Math.max(fromFreq, 1), startTime);
				osc.frequency.exponentialRampToValueAtTime(Math.max(toFreq, 1), startTime + duration);
				gain.gain.setValueAtTime(Math.max(startGain, 0.0001), startTime);
				gain.gain.exponentialRampToValueAtTime(Math.max(endGain, 0.0001), startTime + duration);
				osc.connect(gain);
				gain.connect(ctx.destination);
				osc.start(startTime);
				osc.stop(startTime + duration);
			};

			const playCoinSound = async () => {
				if (isSoundMuted) {
					return;
				}
				const ctx = await ensureAudioContext();
				if (!ctx) {
					return;
				}
				const start = ctx.currentTime + 0.01;
				playTone(ctx, 'square', start, 0.07, 830, 1046, 0.14, 0.001);
				playTone(ctx, 'square', start + 0.08, 0.09, 1046, 1318, 0.16, 0.001);
			};

			const playPowerUpSound = async () => {
				if (isSoundMuted) {
					return;
				}
				const ctx = await ensureAudioContext();
				if (!ctx) {
					return;
				}
				const start = ctx.currentTime + 0.01;
				playTone(ctx, 'sawtooth', start, 0.26, 240, 820, 0.09, 0.001);
				playTone(ctx, 'triangle', start + 0.08, 0.3, 420, 1240, 0.08, 0.001);
			};

			const playExplosionSound = async () => {
				if (isSoundMuted) {
					return;
				}
				const ctx = await ensureAudioContext();
				if (!ctx) {
					return;
				}
				const start = ctx.currentTime + 0.01;
				playTone(ctx, 'sawtooth', start, 0.4, 240, 38, 0.18, 0.001);
				playTone(ctx, 'square', start + 0.02, 0.32, 140, 26, 0.12, 0.001);
			};

			const playCountdownTickSound = async () => {
				if (isSoundMuted) {
					return;
				}
				const ctx = await ensureAudioContext();
				if (!ctx) {
					return;
				}
				const start = ctx.currentTime + 0.01;
				playTone(ctx, 'square', start, 0.06, 620, 560, 0.1, 0.001);
				playTone(ctx, 'triangle', start + 0.04, 0.08, 440, 380, 0.07, 0.001);
			};

			const playFightSound = async () => {
				if (isSoundMuted) {
					return;
				}
				const ctx = await ensureAudioContext();
				if (!ctx) {
					return;
				}
				const start = ctx.currentTime + 0.01;
				playTone(ctx, 'sawtooth', start, 0.14, 260, 720, 0.14, 0.001);
				playTone(ctx, 'square', start + 0.08, 0.2, 880, 1320, 0.16, 0.001);
				playTone(ctx, 'triangle', start + 0.2, 0.14, 660, 980, 0.11, 0.001);
			};

			const applySoundPreference = (muted: boolean) => {
				isSoundMuted = muted;
				if (!soundToggle) {
					return;
				}
				soundToggle.textContent = `Sound: ${muted ? 'Off' : 'On'}`;
				soundToggle.setAttribute('aria-pressed', muted ? 'true' : 'false');
			};

			const toggleSound = async () => {
				const nextMuted = !isSoundMuted;
				applySoundPreference(nextMuted);
				localStorage.setItem(soundMutedStorageKey, String(nextMuted));
				if (!nextMuted) {
					await playCoinSound();
				}
			};

			const clearInputValidation = () => {
				p1Input?.classList.remove('input-invalid');
				p2Input?.classList.remove('input-invalid');
				p1Input?.removeAttribute('aria-invalid');
				p2Input?.removeAttribute('aria-invalid');
			};

			const sleep = (ms: number): Promise<void> => {
				return new Promise((resolve) => {
					window.setTimeout(resolve, ms);
				});
			};

			const runBattleCountdown = async () => {
				if (!battleOverlay || !countdownText) {
					return;
				}

				const steps = ['3...', '2...', '1...', '⚡ FIGHT! ⚡'];
				battleOverlay.classList.add('visible');

				for (const step of steps) {
					countdownText.textContent = step;
					countdownText.classList.remove('step');
					void countdownText.offsetWidth;
					countdownText.classList.add('step');
					if (step === '⚡ FIGHT! ⚡') {
						await playFightSound();
					} else {
						await playCountdownTickSound();
					}
					await sleep(1000);
				}

				battleOverlay.classList.remove('visible');
			};

			const startResultsSlideIn = () => {
				if (!resultsArea) {
					return;
				}
				resultsArea.classList.remove('results-slide-in');
				void resultsArea.offsetWidth;
				resultsArea.classList.add('results-slide-in');
			};

			const showFormError = (message: string) => {
				if (formError) {
					formError.textContent = message;
					formError.classList.add('visible');
				}
				if (battleForm) {
					battleForm.classList.remove('shake-error');
					void battleForm.offsetWidth;
					battleForm.classList.add('shake-error');
				}
			};

			const clearFormError = () => {
				clearInputValidation();
				if (formError) {
					formError.textContent = '';
					formError.classList.remove('visible');
				}
				battleForm?.classList.remove('shake-error');
			};

			const clearWinnerBanner = () => {
				if (!winnerBanner) {
					return;
				}
				winnerBanner.textContent = '';
				winnerBanner.className = 'winner-banner';
			};

			const showWinnerBanner = (message: string, isTie: boolean) => {
				if (!winnerBanner) {
					return;
				}
				winnerBanner.textContent = message;
				winnerBanner.className = `winner-banner visible ${isTie ? 'tie' : ''}`.trim();
			};

			const readBattleHistory = (): BattleHistoryEntry[] => {
				try {
					const raw = localStorage.getItem(battleHistoryStorageKey);
					if (!raw) {
						return [];
					}
					const parsed = JSON.parse(raw);
					if (!Array.isArray(parsed)) {
						return [];
					}
					return parsed as BattleHistoryEntry[];
				} catch {
					return [];
				}
			};

			const formatBattleDateTime = (isoDate: string): string => {
				const parsed = new Date(isoDate);
				if (Number.isNaN(parsed.getTime())) {
					return 'Unknown time';
				}
				return parsed.toLocaleString(undefined, {
					year: 'numeric',
					month: 'short',
					day: 'numeric',
					hour: 'numeric',
					minute: '2-digit'
				});
			};

			const renderBattleHistory = (history: BattleHistoryEntry[]) => {
				if (!recentBattlesList) {
					return;
				}

				if (history.length === 0) {
					recentBattlesList.innerHTML = '<li class="recent-battle-empty">No battles yet. Run a battle to start your leaderboard history!</li>';
					return;
				}

				recentBattlesList.innerHTML = history.map((entry) => `
					<li class="recent-battle-item">
						<div class="recent-battle-top">
							<strong class="recent-battle-winner">Winner: ${escapeHtml(entry.winner)}</strong>
							<span class="recent-battle-time">${formatBattleDateTime(entry.battledAt)}</span>
						</div>
						<p class="recent-battle-score">
							${escapeHtml(entry.player1)}: <strong>${entry.player1Total.toLocaleString()}</strong> VS
							${escapeHtml(entry.player2)}: <strong>${entry.player2Total.toLocaleString()}</strong>
						</p>
					</li>
				`).join('');
			};

			const saveBattleHistoryEntry = (entry: BattleHistoryEntry) => {
				const current = readBattleHistory();
				const updated = [entry, ...current].slice(0, 10);
				localStorage.setItem(battleHistoryStorageKey, JSON.stringify(updated));
				renderBattleHistory(updated);
			};

			const clearBattleHistory = () => {
				localStorage.removeItem(battleHistoryStorageKey);
				renderBattleHistory([]);
			};

			const validateInputs = (p1: string, p2: string): string | null => {
				clearInputValidation();
				const invalidInputs: HTMLInputElement[] = [];
				const errors: string[] = [];

				if (!p1) {
					invalidInputs.push(p1Input!);
					errors.push('Player 1 username is required.');
				}
				if (!p2) {
					invalidInputs.push(p2Input!);
					errors.push('Player 2 username is required.');
				}

				if (p1 && !githubUsernameRegex.test(p1)) {
					invalidInputs.push(p1Input!);
					errors.push('Player 1 username is invalid. Use 1-39 letters, numbers, or single hyphens (not at start/end).');
				}
				if (p2 && !githubUsernameRegex.test(p2)) {
					invalidInputs.push(p2Input!);
					errors.push('Player 2 username is invalid. Use 1-39 letters, numbers, or single hyphens (not at start/end).');
				}

				if (errors.length > 0) {
					invalidInputs.forEach((input) => {
						input.classList.add('input-invalid');
						input.setAttribute('aria-invalid', 'true');
					});
					invalidInputs[0]?.focus();
					return errors.join(' ');
				}

				return null;
			};

			const fetchContributions = async (username: string): Promise<ContributionData> => {
				const res = await fetch(`/api/contributions/${username}`);
				if (!res.ok) {
					throw new Error(`Failed to fetch ${username}`);
				}
				const data = await res.json();
				if (data.error) {
					throw new Error(data.error);
				}
				return data;
			};

			const renderGrid = (data: ContributionData): string => {
				const { colors_full, weeks } = data;
				const palette = (Array.isArray(colors_full) && colors_full.length > 0 ? colors_full : ['#ebedf0']).filter((color): color is string => typeof color === 'string');
				const legendScale = palette.map((color) => `<span class="contrib-legend-cell" style="background-color: ${color};" aria-hidden="true"></span>`).join('');
				return `
					<div class="contrib-grid">
						${weeks.map(week => `
							<div class="contrib-week">
								${week.contribution_days.map(day => {
									const color = colors_full?.[day.level] || '#ebedf0';
									// Calculate actual date for the tooltip without timezone shift
									const [y, m, d] = week.first_day.split('-').map(Number);
									const dateObj = new Date(y, m - 1, d);
									dateObj.setDate(dateObj.getDate() + day.weekday);
									const dateStr = dateObj.toLocaleDateString(undefined, { 
										month: 'short', day: 'numeric', year: 'numeric' 
									});
									
									return `<div class="contrib-day" style="background-color: ${color}" title="${day.count} contributions on ${dateStr}"></div>`;
								}).join('')}
							</div>
						`).join('')}
					</div>
					<div class="contrib-legend" aria-label="Contribution legend from less to more">
						<span class="contrib-legend-scale">${legendScale}</span>
					</div>
				`;
			};

			const renderUserResult = (username: string, data: ContributionData, isWinner: boolean, isDraw: boolean): string => {
				const statusIcon = isDraw ? '🤝' : isWinner ? '🏆' : '💀';
				const statusText = isDraw ? 'Draw' : isWinner ? 'Winner' : 'Loser';
				const fromDate = new Date(data.from).toLocaleDateString();
				const toDate = new Date(data.to).toLocaleDateString();
				
				return `
					<h3 style="word-break: break-word; line-height: 1.4;">
						<span style="vertical-align: middle; font-size: 1.2em; margin-right: 0.25rem;">${statusIcon}</span>
						<span style="vertical-align: middle;">${statusText}: <br/> ${username}</span>
					</h3>
					<p>Contributions: <strong>${data.total_contributions.toLocaleString()}</strong></p>
					<p><small>${fromDate} - ${toDate}</small></p>
					${renderGrid(data)}
				`;
			};

			const renderError = (username: string, errorMsg: string): string => {
				return `
					<h3>${username}</h3>
					<p class="error-message">Error: ${errorMsg}</p>
				`;
			};

			const handleBattle = async (event?: Event) => {
				event?.preventDefault();
				if (isBattleInProgress) {
					return;
				}
				if (!p1Input || !p2Input) {
					return;
				}
				const p1 = p1Input.value.trim();
				const p2 = p2Input.value.trim();

				const inputError = validateInputs(p1, p2);
				if (inputError) {
					showFormError(inputError);
					void playExplosionSound();
					return;
				}
				clearFormError();

				if (resultsArea && resultP1 && resultP2) {
					isBattleInProgress = true;
					battleBtn?.setAttribute('disabled', 'true');
					await runBattleCountdown();
					resultsArea.style.display = 'block';
					startResultsSlideIn();
					resultsArea.focus();
					clearWinnerBanner();
					void playCoinSound();
					resultP1.innerHTML = `<h3>${p1}</h3><p class="loading-pulse">Fetching data...</p>`;
					resultP2.innerHTML = `<h3>${p2}</h3><p class="loading-pulse">Fetching data...</p>`;
					resultP1.className = 'player-result';
					resultP2.className = 'player-result';

					try {
						const [data1, data2] = await Promise.all([
							fetchContributions(p1).catch(err => ({ error: err.message } as ContributionData)),
							fetchContributions(p2).catch(err => ({ error: err.message } as ContributionData))
						]);

						const hasError1 = !!data1.error;
						const hasError2 = !!data2.error;
						const hasAnyError = hasError1 || hasError2;

						if (hasError1) {
							resultP1.innerHTML = renderError(p1, data1.error!);
							resultP1.className = 'player-result loser';
						}
						
						if (hasError2) {
							resultP2.innerHTML = renderError(p2, data2.error!);
							resultP2.className = 'player-result loser';
						}

						if (hasAnyError) {
							void playExplosionSound();
						}

						if (!hasError1 && !hasError2) {
							const t1 = data1.total_contributions || 0;
							const t2 = data2.total_contributions || 0;
							const isDraw = t1 === t2;
							const winnerName = isDraw ? 'Tie' : t1 > t2 ? p1 : p2;

							if (isDraw) {
								showWinnerBanner("🤝 IT'S A TIE! 🤝", true);
							} else {
								showWinnerBanner(`🏆 ${winnerName} WINS! 🏆`, false);
							}

							saveBattleHistoryEntry({
								player1: p1,
								player1Total: t1,
								player2: p2,
								player2Total: t2,
								winner: winnerName,
								battledAt: new Date().toISOString()
							});

							void playPowerUpSound();
							
							resultP1.innerHTML = renderUserResult(p1, data1, t1 > t2, isDraw);
							resultP2.innerHTML = renderUserResult(p2, data2, t2 > t1, isDraw);
							
							resultP1.className = `player-result ${isDraw ? '' : t1 > t2 ? 'winner' : 'loser'}`;
							resultP2.className = `player-result ${isDraw ? '' : t2 > t1 ? 'winner' : 'loser'}`;
						}
					} catch (err) {
						console.error(err);
						void playExplosionSound();
					} finally {
						isBattleInProgress = false;
						battleBtn?.removeAttribute('disabled');
					}
				}
			};

			p1Input?.addEventListener('input', clearFormError);
			p2Input?.addEventListener('input', clearFormError);
			battleForm?.addEventListener('submit', handleBattle);
			soundToggle?.addEventListener('click', () => {
				void toggleSound();
			});
			clearHistoryBtn?.addEventListener('click', clearBattleHistory);
			renderBattleHistory(readBattleHistory());
			applySoundPreference(localStorage.getItem(soundMutedStorageKey) === 'true');
			const savedTheme = localStorage.getItem(themeStorageKey);
			applyTheme(savedTheme === altTheme ? altTheme : defaultTheme);
			themeToggle?.addEventListener('click', () => {
				const current = document.body.getAttribute('data-theme');
				const nextTheme = current === altTheme ? defaultTheme : altTheme;
				applyTheme(nextTheme);
				localStorage.setItem(themeStorageKey, nextTheme);
			});
		</script>
	</body>
</html>
